# =============================================================================
# Geist — Environment Variables (copy to .env and fill in your values)
# cp .env.example .env
# =============================================================================

# Backend API
API_HOST=0.0.0.0
API_PORT=8080

# Massive Advanced API — OTC / fragmented markets
MASSIVE_API_KEY=your_massive_api_key_here
MASSIVE_API_BASE_URL=https://api.massive.com

# Monad Testnet
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
PRIVATE_KEY=

# Frontend (safe for browser)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_EXECUTION_GRAPH_REGISTRY_ADDRESS=

# Discovery Agent (server-side only)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Set DISCOVERY_USE_LLM=false to skip OpenAI on scan (uses corpus_rank fallback)
# X — home timeline (your feed, first 5 posts) requires OAuth 1.0a user keys:
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
# Bearer token is fallback public search only (not your account feed):
X_BEARER_TOKEN=your_x_bearer_token_here
PYTHON_BIN=python
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=geist-discovery/1.0 (Monad hackathon demo)

# Optional future integrations
# X402_PAYMENT_RECEIVER=
# KURU_FLOW_API_URL=
# ERC8004_AGENT_ID=
